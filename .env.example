# Bot token (BotFather dan olinadi)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID lari (vergul bilan)
ADMIN_IDS=123456789,987654321

# Ma'lumotlar bazasi
DATABASE_URL=sqlite+aiosqlite:///./tandir_bot.db

# Bot ma'lumotlari
BOT_USERNAME=your_bot_username

# Kanal havolasi
CHANNEL_URL=https://t.me/your_channel

# Admin kontakt
ADMIN_TELEGRAM=https://t.me/admin_username
ADMIN_PHONE=+998901234567

# Manzil
COMPANY_ADDRESS=Toshkent shahri, ...

# Log darajasi (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
